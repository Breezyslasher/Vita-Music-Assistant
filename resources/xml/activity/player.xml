<?xml version="1.0" encoding="utf-8"?>
<brls:Box
    id="player/container"
    width="100%"
    height="100%"
    axis="column"
    justifyContent="flexEnd"
    alignItems="stretch">

    <!-- Album art for music (centered above controls) -->
    <brls:Box
        id="player/album_art_container"
        width="100%"
        grow="1"
        axis="column"
        justifyContent="center"
        alignItems="center">
        <brls:Image
            id="player/album_art"
            width="220"
            height="220"
            scalingType="fit"
            cornerRadius="14"
            visibility="gone"/>

    </brls:Box>

    <!-- Music info area: title + artist between album art and play controls -->
    <brls:Box
        id="player/music_info"
        width="100%"
        axis="column"
        alignItems="center"
        visibility="gone"
        marginBottom="8"
        marginTop="4"
        paddingLeft="24"
        paddingRight="24">
        <brls:Label
            id="player/music_title"
            text=""
            fontSize="22"
            horizontalAlign="center"
            textColor="#FFFFFF"
            marginBottom="4"/>
        <brls:Label
            id="player/music_artist"
            text=""
            fontSize="16"
            horizontalAlign="center"
            textColor="#BBBBBB"/>
    </brls:Box>

    <!-- Music transport controls (shuffle/prev/play/next/repeat) -->
    <brls:Box
        id="player/music_transport"
        width="100%"
        axis="row"
        justifyContent="center"
        alignItems="center"
        marginBottom="6">

        <!-- Shuffle toggle button -->
        <brls:Box
            id="player/shuffle_btn"
            width="48"
            height="48"
            axis="row"
            justifyContent="center"
            alignItems="center"
            cornerRadius="24"
            marginRight="16"
            focusable="true">
            <brls:Image
                id="player/shuffle_icon"
                width="24"
                height="24"
                image="@res/icons/shuffle-disabled.png"
                scalingType="fit"/>
        </brls:Box>

        <!-- Previous button -->
        <brls:Box
            id="player/music_prev_btn"
            width="60"
            height="60"
            axis="row"
            justifyContent="center"
            alignItems="center"
            cornerRadius="30"
            marginRight="24"
            focusable="true">
            <brls:Image
                id="player/music_prev_icon"
                width="36"
                height="36"
                image="@res/icons/skip-previous.png"
                scalingType="fit"/>
        </brls:Box>

        <!-- Play/Pause button -->
        <brls:Box
            id="player/music_play_btn"
            width="80"
            height="80"
            axis="row"
            justifyContent="center"
            alignItems="center"
            cornerRadius="40"
            focusable="true">
            <brls:Image
                id="player/music_play_icon"
                width="44"
                height="44"
                image="@res/icons/pause.png"
                scalingType="fit"/>
        </brls:Box>

        <!-- Next button -->
        <brls:Box
            id="player/music_next_btn"
            width="60"
            height="60"
            axis="row"
            justifyContent="center"
            alignItems="center"
            cornerRadius="30"
            marginLeft="24"
            focusable="true">
            <brls:Image
                id="player/music_next_icon"
                width="36"
                height="36"
                image="@res/icons/skip-next.png"
                scalingType="fit"/>
        </brls:Box>

        <!-- Repeat toggle button -->
        <brls:Box
            id="player/repeat_btn"
            width="48"
            height="48"
            axis="row"
            justifyContent="center"
            alignItems="center"
            cornerRadius="24"
            marginLeft="16"
            focusable="true">
            <brls:Image
                id="player/repeat_icon"
                width="24"
                height="24"
                image="@res/icons/repeat-off.png"
                scalingType="fit"/>
        </brls:Box>

    </brls:Box>

    <!-- Controls overlay - positioned at bottom -->
    <brls:Box
        id="player/controls"
        width="100%"
        axis="column"
        alignItems="stretch"
        padding="15"
        backgroundColor="#80000000"
        cornerRadius="8"
        marginLeft="20"
        marginRight="20"
        marginBottom="20">

        <!-- Title -->
        <brls:Label
            id="player/title"
            text="Now Playing"
            fontSize="20"
            marginBottom="5"/>

        <!-- Artist -->
        <brls:Label
            id="player/artist"
            text=""
            fontSize="16"
            textColor="#AAAAAA"
            marginBottom="5"
            visibility="gone"/>

        <!-- Queue info (track X of Y, shuffle/repeat status) -->
        <brls:Label
            id="player/queue_info"
            text=""
            fontSize="12"
            textColor="#888888"
            marginBottom="8"
            visibility="gone"/>

        <!-- Progress slider -->
        <brls:Slider
            id="player/progress"
            width="100%"
            height="40"
            marginBottom="2"/>

        <!-- Time display: elapsed on left, remaining on right -->
        <brls:Box
            width="100%"
            axis="row"
            justifyContent="spaceBetween"
            alignItems="center"
            marginBottom="8">
            <brls:Label
                id="player/time_elapsed"
                text="0:00"
                fontSize="13"
                textColor="#AAAAAA"/>
            <brls:Label
                id="player/time_remaining"
                text="-0:00"
                fontSize="13"
                textColor="#AAAAAA"/>
        </brls:Box>

        <!-- Queue + player switcher buttons -->
        <brls:Box
            width="100%"
            axis="row"
            justifyContent="center"
            alignItems="center">

            <brls:Box
                id="player/queue_btn"
                width="64"
                height="64"
                axis="row"
                justifyContent="center"
                alignItems="center"
                cornerRadius="32"
                focusable="true"
                visibility="gone">
                <brls:Image
                    id="player/queue_icon"
                    width="34"
                    height="34"
                    image="@res/icons/format-list-group.png"
                    scalingType="fit"/>
            </brls:Box>

            <!-- Player switcher button with name -->
            <brls:Box
                id="player/player_switch_btn"
                height="44"
                axis="row"
                justifyContent="center"
                alignItems="center"
                cornerRadius="22"
                focusable="true"
                marginLeft="16"
                paddingLeft="12"
                paddingRight="14"
                visibility="gone">
                <brls:Image
                    id="player/player_switch_icon"
                    width="22"
                    height="22"
                    image="@res/icons/speaker-multiple.png"
                    scalingType="fit"/>
                <brls:Label
                    id="player/player_name_label"
                    text="This Vita"
                    fontSize="13"
                    marginLeft="6"/>
            </brls:Box>

        </brls:Box>

    </brls:Box>

    <!-- Queue list overlay - slides up from bottom -->
    <brls:Box
        id="player/queue_overlay"
        width="100%"
        height="100%"
        axis="column"
        justifyContent="flexEnd"
        alignItems="stretch"
        positionType="absolute"
        positionTop="0"
        positionLeft="0"
        positionRight="0"
        positionBottom="0"
        backgroundColor="#CC000000"
        visibility="gone">

        <!-- Spacer to push queue to bottom half -->
        <brls:Box grow="1"/>

        <!-- Queue panel at bottom -->
        <brls:Box
            width="100%"
            axis="column"
            alignItems="stretch"
            backgroundColor="#F0141420"
            cornerRadius="18"
            paddingTop="16"
            paddingBottom="16"
            paddingLeft="20"
            paddingRight="20"
            marginLeft="10"
            marginRight="10"
            marginBottom="10"
            borderColor="#30FFFFFF"
            borderThickness="1">

            <!-- Queue title -->
            <brls:Label
                id="player/queue_overlay_title"
                text="Queue"
                fontSize="19"
                textColor="#EEEEEE"
                horizontalAlign="center"
                marginBottom="12"/>

            <!-- Queue track list container (scrollable) -->
            <brls:ScrollingFrame
                id="player/queue_scroll"
                width="100%"
                height="320">
                <brls:Box
                    id="player/queue_list"
                    width="100%"
                    axis="column"
                    alignItems="stretch"
                    padding="4"/>
            </brls:ScrollingFrame>

        </brls:Box>

    </brls:Box>

</brls:Box>
